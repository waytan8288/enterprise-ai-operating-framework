# =============================================================================
# Enterprise AI Operating Framework Configuration
# =============================================================================

# LLM Configuration (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# =============================================================================
# Data Source Configuration
# =============================================================================

# Connector type: sqlite | mysql | snowflake
CONNECTOR_TYPE=sqlite

# SQLite (default)
SQLITE_DB_PATH=./data/enterprise.db

# MySQL (if CONNECTOR_TYPE=mysql)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Snowflake (if CONNECTOR_TYPE=snowflake)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# =============================================================================
# Knowledge Graph
# =============================================================================

KG_STORE_TYPE=sqlite
KG_SQLITE_PATH=./data/knowledge_graph.db

# =============================================================================
# Authentication
# =============================================================================

AUTH_SECRET_KEY=change-me-in-production
LANGGRAPH_LOCAL_DEV=1

# Feature flags for local dev (comma-separated)
LOCAL_DEV_FEATURE_FLAGS=enable_insight_agent,enable_strategy_agent,enable_act_agent,enable_measure_agent,enable_learn_agent,enable_govern_agent

# =============================================================================
# LangSmith Observability (optional)
# =============================================================================

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-ai-operating-framework
